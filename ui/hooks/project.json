{
  "name": "ui-hooks",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "ui/hooks/src",
  "projectType": "library",
  "tags": ["npm:public", "scope:ui", "layer:ui-foundation"],
  "// targets": "to see all targets run: nx show project ui-hooks --web",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "ui/hooks",
        "command": "tsc --build tsconfig.lib.json"
      },
      "outputs": ["{projectRoot}/dist"]
    }
  }
}
