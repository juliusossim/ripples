{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node", "@nx/react/typings/cssmodule.d.ts", "@nx/react/typings/image.d.ts"],
    "rootDir": "src",
    "jsx": "react-jsx",
    "lib": ["dom", "es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "paths": {}
  },
  "exclude": [
    "out-tsc",
    "dist",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "**/__tests__/**",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.spec.tsx",
    "**/*.test.tsx",
    "**/*.spec.js",
    "**/*.test.js",
    "**/*.spec.jsx",
    "**/*.test.jsx",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "src/**/*.spec.js",
    "src/**/*.test.js",
    "src/**/*.spec.jsx",
    "src/**/*.test.jsx",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "include": [
    "src/index.ts",
    "src/lib/index.ts",
    "src/lib/amount/index.ts",
    "src/lib/amount/amount.tsx",
    "src/lib/amount/amount.types.ts",
    "src/lib/badge/index.ts",
    "src/lib/badge/brand-badge/**/*.ts",
    "src/lib/badge/brand-badge/**/*.tsx",
    "src/lib/card/index.ts",
    "src/lib/card/fashion-card/**/*.ts",
    "src/lib/card/fashion-card/**/*.tsx",
    "src/lib/card/property-card/**/*.ts",
    "src/lib/card/property-card/**/*.tsx",
    "src/lib/carousel/index.ts",
    "src/lib/carousel/brand-carousel/**/*.ts",
    "src/lib/carousel/brand-carousel/**/*.tsx",
    "src/lib/carousel/media-carousel/**/*.ts",
    "src/lib/carousel/media-carousel/**/*.tsx",
    "src/lib/carousel/product-carousel/**/*.ts",
    "src/lib/carousel/product-carousel/**/*.tsx",
    "src/lib/carousel/property-carousel/**/*.ts",
    "src/lib/carousel/property-carousel/**/*.tsx",
    "src/lib/command/**/*.ts",
    "src/lib/command/**/*.tsx",
    "src/lib/error-message/index.ts",
    "src/lib/error-message/error-message.tsx",
    "src/lib/error-message/error-message.types.ts",
    "src/lib/form/**/*.ts",
    "src/lib/form/**/*.tsx",
    "src/lib/grid/**/*.ts",
    "src/lib/grid/**/*.tsx",
    "src/lib/hooks/index.ts",
    "src/lib/loading-spinner/index.ts",
    "src/lib/loading-spinner/loading-spinner.tsx",
    "src/lib/loading-spinner/loading-spinner.types.ts",
    "src/lib/media/index.ts",
    "src/lib/nav/index.ts",
    "src/lib/nav/nav-list-item/**/*.ts",
    "src/lib/nav/nav-list-item/**/*.tsx",
    "src/lib/nav/nav-menu/**/*.ts",
    "src/lib/nav/nav-menu/**/*.tsx",
    "src/lib/social-interactions/index.ts",
    "src/lib/social-interactions/social-interactions.tsx",
    "src/lib/social-interactions/social-interactions.types.ts",
    "src/lib/stars/index.ts",
    "src/lib/stars/star-rating.tsx",
    "src/lib/stars/star-rating.types.ts",
    "src/lib/typography/index.ts",
    "src/lib/typography/more-info-text.tsx",
    "src/lib/typography/typography.tsx",
    "src/lib/typography/typography.constants.ts",
    "src/lib/typography/typography.types.ts"
  ],
  "references": [
    {
      "path": "../primitives/tsconfig.lib.json"
    },
    {
      "path": "../../shared/utils/tsconfig.lib.json"
    },
    {
      "path": "../hooks/tsconfig.lib.json"
    }
  ]
}
