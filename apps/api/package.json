{
  "name": "@org/api",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "targets": {
      "typecheck": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "prisma-generate",
          "^typecheck"
        ],
        "options": {
          "command": "tsc --build tsconfig.json --emitDeclarationOnly",
          "cwd": "apps/api"
        }
      },
      "build": {
        "executor": "nx:run-commands",
        "dependsOn": [
          "prisma-generate"
        ],
        "options": {
          "command": "webpack-cli build",
          "args": [
            "--node-env=production"
          ],
          "cwd": "apps/api"
        },
        "configurations": {
          "development": {
            "args": [
              "--node-env=development"
            ]
          }
        }
      },
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "jest",
          "cwd": "apps/api"
        }
      },
      "prisma-generate": {
        "executor": "nx:run-commands",
        "options": {
          "command": "prisma generate",
          "cwd": "apps/api"
        }
      },
      "migrate-deploy": {
        "executor": "nx:run-commands",
        "options": {
          "command": "prisma migrate deploy",
          "cwd": "apps/api"
        }
      },
      "migrate-dev": {
        "executor": "nx:run-commands",
        "options": {
          "command": "prisma migrate dev",
          "cwd": "apps/api"
        }
      },
      "prisma-studio": {
        "continuous": true,
        "executor": "nx:run-commands",
        "options": {
          "command": "prisma studio",
          "cwd": "apps/api"
        }
      },
      "prune-lockfile": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "executor": "@nx/js:prune-lockfile",
        "outputs": [
          "{workspaceRoot}/apps/api/dist/package.json",
          "{workspaceRoot}/apps/api/dist/pnpm-lock.yaml"
        ],
        "options": {
          "buildTarget": "build"
        }
      },
      "copy-workspace-modules": {
        "dependsOn": [
          "build"
        ],
        "cache": true,
        "outputs": [
          "{workspaceRoot}/apps/api/dist/workspace_modules"
        ],
        "executor": "@nx/js:copy-workspace-modules",
        "options": {
          "buildTarget": "build"
        }
      },
      "prune": {
        "dependsOn": [
          "prune-lockfile",
          "copy-workspace-modules"
        ],
        "executor": "nx:noop"
      },
      "serve": {
        "continuous": true,
        "executor": "@nx/js:node",
        "defaultConfiguration": "development",
        "dependsOn": [
          "build"
        ],
        "options": {
          "buildTarget": "api:build",
          "runBuildTargetDependencies": false
        },
        "configurations": {
          "development": {
            "buildTarget": "api:build:development"
          },
          "production": {
            "buildTarget": "api:build:production"
          }
        }
      }
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@org/types": "workspace:*",
    "@org/utils": "workspace:*",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie": "^1.1.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.0.0",
    "prisma": "^7.7.0"
  }
}
