{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "out-tsc/jest",
    "rootDir": "../..",
    "tsBuildInfoFile": "out-tsc/jest/tsconfig.spec.tsbuildinfo",
    "types": ["jest", "node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "paths": {}
  },
  "include": ["jest.config.cts", "src/**/*.ts", "src/**/*.d.ts"],
  "references": [
    {
      "path": "../../shared/types/tsconfig.lib.json"
    },
    {
      "path": "../../shared/utils/tsconfig.lib.json"
    }
  ]
}
