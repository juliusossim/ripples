{
  "name": "ripples",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "dev": "pnpm nx run-many -t dev -p web,api --parallel=2",
    "dev:api": "pnpm nx run api:dev",
    "dev:web": "pnpm nx run web:dev",
    "build": "pnpm nx run-many -t build",
    "typecheck": "pnpm nx run-many -t typecheck",
    "test": "pnpm nx run-many -t test",
    "test:coverage": "pnpm nx run-many -t test -p api,types,api-client,@org/data,ui-web,web -- --coverage",
    "lint": "pnpm nx run-many -t lint",
    "lint:fix": "pnpm nx run-many -t lint -- --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:affected": "pnpm nx affected -t build",
    "test:affected": "pnpm nx affected -t test",
    "lint:affected": "pnpm nx affected -t lint",
    "sync": "pnpm nx sync",
    "graph": "pnpm nx graph",
    "reset": "pnpm nx reset",
    "clean": "pnpm nx reset && rm -rf dist",
    "prisma:generate": "pnpm nx run api:prisma-generate",
    "prisma:migrate": "pnpm prisma:migrate:dev",
    "prisma:migrate:dev": "pnpm nx run api:migrate-dev",
    "prisma:migrate:deploy": "pnpm nx run api:migrate-deploy",
    "prisma:studio": "pnpm nx run api:prisma-studio",
    "sonar": "sonar-scanner"
  },
  "private": true,
